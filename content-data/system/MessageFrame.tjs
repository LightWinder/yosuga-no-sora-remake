/*
	メッセージフレーム
*/

// ADV / backlog 文本全局样式。
// 预渲染字体只有 12/24/30/36/48 档；50px 正文使用 48px 字形和
// 50px 行高，40px backlog 使用 36px 字形和 40px 行高。
var ADV_TEXT_STYLE = %[
	messageFontSize:50,
	messagePrerenderedSize:48,
	messageLineHeight:50,
	backlogFontSize:40,
	backlogPrerenderedSize:36,
	backlogLineHeight:40,
	unreadColor:0xFFFFFF,
	readColor:0xB8DDE7,
	shadowColor:0x165768,
	shadowLevel:3002,
	shadowWidth:1,
	messageShadowX:3,
	messageShadowY:3,
	backlogShadowX:2,
	backlogShadowY:2
];

var ADV_FONT_NAME_FACE = "30";		// 角色名（小说模式 fallback）
var ADV_FONT_NAME_SIZE = 30;
var ADV_FONT_MESS_SIZE = ADV_TEXT_STYLE.messageFontSize;
var ADV_FONT_MESS_INDENT = ADV_TEXT_STYLE.messageLineHeight;
function GetAdvFontMessFace(){
	return string ADV_TEXT_STYLE.messagePrerenderedSize;
}
var ADV_FONT_MESS_FACE = GetAdvFontMessFace();	// 由 SIZE 派生

function GetBacklogFontFace(){
	return string ADV_TEXT_STYLE.backlogPrerenderedSize;
}

function ApplyAdvTextDrawStyle(area, read=false){
	var color = read ? ADV_TEXT_STYLE.readColor : ADV_TEXT_STYLE.unreadColor;
	area.setDefaultDrawTextParam(
		color, 255, true,
		ADV_TEXT_STYLE.shadowLevel, ADV_TEXT_STYLE.shadowColor,
		ADV_TEXT_STYLE.shadowWidth,
		ADV_TEXT_STYLE.messageShadowX, ADV_TEXT_STYLE.messageShadowY);
	area.resetDrawTextParam();
}

function ApplyBacklogTextDrawStyle(area){
	area.setDefaultDrawTextParam(
		ADV_TEXT_STYLE.unreadColor, 255, true,
		ADV_TEXT_STYLE.shadowLevel, ADV_TEXT_STYLE.shadowColor,
		ADV_TEXT_STYLE.shadowWidth,
		ADV_TEXT_STYLE.backlogShadowX, ADV_TEXT_STYLE.backlogShadowY);
	area.resetDrawTextParam();
}

