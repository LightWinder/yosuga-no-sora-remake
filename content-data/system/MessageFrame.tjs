var ROLE_NAME_IMAGE_DEFAULT = "nothing.png";

function MessageNameUiFile(file){
	return MESSAGE_NAME_UI_PATH + file;
}
function GetMessageRoleNameImage(roleName){
	var file = ROLE_NAME_IMAGE_DEFAULT;
	for(var i=0; i<ROLE_NAME_IMAGES.count; i++){
		if(ROLE_NAME_IMAGES[i][0] == roleName){
			file = ROLE_NAME_IMAGES[i][1];
			break;
		}
	}
	return MessageNameUiFile(file);
}
function ResolveMessageRoleNameImageFile(roleName){
	var file = GetMessageRoleNameImage(roleName);
	if(Storages.isExistentStorage(file)) return file;
	file = MessageNameUiFile("nothing.png");
	if(Storages.isExistentStorage(file)) return file;
	return "";
}

class MessageFrame extends Sprite, SelectItemNotifyBase{
	var _isShow;

	var _name, _mess, _voice, _pan, _volume;

	var _advObj;

	var _base;

	var _msgBase = [];
	var _maName, _maMess, _imgName;

	var _imgFace;
	var _currentFace = "";
	var _layoutFace = "";	// 当前消息框实际展示的立绘 id（供语音收藏）
	var _lastBustupMap = %[];

	var _type = -1;
	var _hidedType = -1;

	var _tgtBlink = null;
	var _blink, _blinkA;
	var _blinkTimer;

	//システムメニュー
	var _systemMenuArea;
	var _systemMenu;
	var _menuCallArea;

	//各種ボタン
