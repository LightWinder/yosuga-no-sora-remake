class TextSettingsMenu extends SubMenu{
	var _adv;
	var _btn = %[];
	var _skipGroup;

	function TextSettingsMenu(win, par, o=null, adv=null){
		SubMenu(...);
		_name = "TextSettingsMenu";
		_adv = adv;
		join = JOIN_TOP;

		// ui贴图
		loadImages("ui_1920/adv_menu/DHK-11.png");
		setSizeToImageSize();
		absolute = 250;

		var sliderW = 220;
		var trimImg = "ui_1920/adv_menu/DHK-44.png";
		var radioImg = "ui_1920/adv_menu/DHK-45.png";

// 这里是写死的，最好不要瞎改
		_btn.MessageSpeed = new SliderH(window, this);
		with(_btn.MessageSpeed){
			.create(trimImg, sliderW, 14, 1, 100);
			.setPos(160, 15);
		}
		_btn.AutoMessageSpeed = new SliderH(window, this);
		with(_btn.AutoMessageSpeed){
			.create(trimImg, sliderW, 14, 1, 100);
			.setPos(160, 49);
		}
		_btn.WindowDepth = new SliderH(window, this);
		with(_btn.WindowDepth){
			.create(trimImg, sliderW, 14, 1, 100);
			.setPos(160, 83);
		}

		_skipGroup = new RadioButtonGroup();
		_btn.SkipRead = new RadioOnBaseButton(window, this);
		with(_btn.SkipRead){
			.create(radioImg, 1, 2, 5, 115, 24);
			.setPos(137, 110);
		}
		_skipGroup.add(_btn.SkipRead);
		_btn.SkipAll = new RadioOnBaseButton(window, this);
		with(_btn.SkipAll){
			.create(radioImg, 1, 2, 5, 115, 24);
			.setPos(283
			, 110);
		}
		_skipGroup.add(_btn.SkipAll);

		addItem(_btn.MessageSpeed);
		addItem(_btn.AutoMessageSpeed);
		addItem(_btn.WindowDepth);
		addItem(_btn.SkipRead);
		addItem(_btn.SkipAll);

		if(CONFIG.readSkip)	_skipGroup.on(_btn.SkipRead);
		else				_skipGroup.on(_btn.SkipAll);
		updateSkipVisual();

		hide();
	}
	function finalize(){
		invalidate _skipGroup;
		super.finalize();
	}

	function onButtonDownL(target){
		applyToSystem();
		updateSkipVisual();
	}
	function onButtonDownR(target){}
	function onSliderEnter(target){}
	function onSliderLeave(target){}
	function onSliderMove(target){applyToSystem();}
	function onSliderMoveStart(target){}
	function onSliderMoveEnd(target){applyToSystem();}

	function loadFromConfig(){
		_btn.MessageSpeed.trim = _btn.MessageSpeed.range - CONFIG.messageSpeed;
		_btn.AutoMessageSpeed.trim = (_btn.AutoMessageSpeed.range*100 - CONFIG.autoSpeed) \ 100;
		_btn.WindowDepth.trim = CONFIG.windowDepth;
		if(CONFIG.readSkip)	_skipGroup.on(_btn.SkipRead);
		else				_skipGroup.on(_btn.SkipAll);
		updateSkipVisual();
	}

	function applyToSystem(){
		CONFIG.messageSpeed = _btn.MessageSpeed.range - _btn.MessageSpeed.trim;
		CONFIG.autoSpeed = (_btn.AutoMessageSpeed.range - _btn.AutoMessageSpeed.trim) * 100;
		CONFIG.windowDepth = _btn.WindowDepth.trim;
		CONFIG.readSkip = _btn.SkipRead.isOn() ? 1 : 0;

		if(_adv){
			_adv._msg._maMess.outputSpeed = CONFIG.messageSpeed;
			_adv._msg.windowDepth((255 * CONFIG.windowDepth) \ 100);
			if(_adv.isAuto() && _adv._autoTimer.enabled)
				_adv._autoTimer.interval = CONFIG.autoSpeed + 1;
		}
	}

	function updateSkipVisual(){
		_btn.SkipRead._check.visible = _btn.SkipRead.isOn();
		_btn.SkipAll._check.visible = _btn.SkipAll.isOn();
	}
}
